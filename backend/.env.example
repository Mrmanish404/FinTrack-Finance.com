PORT=5000
# Use a local MongoDB instance for development if you don't have Atlas credentials.
# Example: mongodb://127.0.0.1:27017/finance-tracker
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/finance-tracker
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
