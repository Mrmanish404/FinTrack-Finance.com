{
  "version": 2,
  "name": "finance-tracker-frontend",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "REACT_APP_API_URL": "https://your-render-backend-url.onrender.com/api"
  }
}
